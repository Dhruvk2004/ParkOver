<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A">

    <!-- Animated gradient background -->
    <View
        android:id="@+id/gradientBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/splash_gradient_bg" />

    <!-- Decorative circles -->
    <View
        android:id="@+id/decorCircle1"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-100dp"
        android:layout_marginEnd="-100dp"
        android:alpha="0"
        android:background="@drawable/splash_circle_decoration" />

    <View
        android:id="@+id/decorCircle2"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="-60dp"
        android:layout_marginBottom="-60dp"
        android:alpha="0"
        android:background="@drawable/splash_circle_decoration" />

    <!-- Main content container -->
    <LinearLayout
        android:id="@+id/contentContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical">

        <!-- Lottie Animation -->
        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/splashAnimation"
            android:layout_width="280dp"
            android:layout_height="280dp"
            app:lottie_rawRes="@raw/splash_animation"
            app:lottie_autoPlay="false"
            app:lottie_loop="false" />

        <!-- App Name -->
        <TextView
            android:id="@+id/appName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:alpha="0"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.05"
            android:text="ParkOver"
            android:textColor="@color/white"
            android:textSize="36sp" />

        <!-- Tagline -->
        <TextView
            android:id="@+id/tagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:alpha="0"
            android:fontFamily="sans-serif-light"
            android:text="Find. Park. Go."
            android:textColor="#B0B0B0"
            android:textSize="16sp"
            android:letterSpacing="0.15" />

    </LinearLayout>

    <!-- Loading indicator at bottom -->
    <LinearLayout
        android:id="@+id/loadingContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="80dp"
        android:gravity="center"
        android:orientation="vertical"
        android:alpha="0">

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/loadingAnimation"
            android:layout_width="60dp"
            android:layout_height="60dp"
            app:lottie_rawRes="@raw/loading_animation"
            app:lottie_autoPlay="true"
            app:lottie_loop="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Loading..."
            android:textColor="#808080"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>

</FrameLayout>
